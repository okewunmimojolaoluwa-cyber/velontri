{

  "name": "velontri",

  "version": "1.0.0",

  "description": "Velontri monorepo — backend APIs and frontend UI",

  "private": true,

  "scripts": {

    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",

    "dev:backend": "npm --prefix backend run dev",

    "dev:gateway": "npm --prefix backend run dev:gateway",

    "dev:docker": "npm --prefix backend run dev:docker",

    "dev:frontend": "npm --prefix frontend run dev",

    "start": "npm --prefix backend run start",

    "stop": "npm --prefix backend run stop",

    "build": "npm --prefix backend run build",

    "test": "npm --prefix backend run test",

    "seed": "python backend/scripts/seed_demo_users.py",

    "test:frontend": "npm --prefix frontend run test",

    "test:e2e": "npm --prefix backend run test:e2e",

    "health": "npm --prefix backend run health",

    "keygen": "npm --prefix backend run keygen",

    "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install"

  },

  "engines": {

    "node": ">=20.0.0"

  },

  "devDependencies": {

    "concurrently": "^8.2.2"

  },

  "dependencies": {

    "@next/swc-win32-x64-msvc": "^16.2.9",

    "@radix-ui/react-avatar": "^1.2.0",

    "@radix-ui/react-dialog": "^1.1.17",

    "@radix-ui/react-dropdown-menu": "^2.1.18",

    "@radix-ui/react-select": "^2.3.1",

    "@radix-ui/react-tabs": "^1.1.15",

    "@tanstack/react-query": "^5.101.1",

    "class-variance-authority": "^0.7.1",

    "cmdk": "^1.1.1",

    "date-fns": "^4.4.0",

    "lucide-react": "^1.21.0",

    "react-hook-form": "^7.80.0",

    "recharts": "^3.9.0",

    "zustand": "^5.0.14"

  }

}

