{
  "info": {
    "name": "Velontri Commerce Platform",
    "description": "Complete API collection for the Velontri Commerce Platform.\n\n**Single API base URL (gateway):**\n`http://localhost:8000/api/v1`\n\nStart the backend first:\n```\nnpm run dev\n```\n\nAuthentication: `Authorization: Bearer {{access_token}}`\nObtain tokens from **Authentication → Login** (auto-saved).\n\nAlternative: import live OpenAPI from `http://localhost:8000/openapi.json` in Postman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": { "major": 1, "minor": 1, "patch": 0 }
  },
  "variable": [
    { "key": "base_url",         "value": "http://localhost:8000/api/v1" },
    { "key": "gateway_url",      "value": "http://localhost:8000" },
    { "key": "auth_url",         "value": "http://localhost:8000/api/v1" },
    { "key": "user_url",         "value": "http://localhost:8000/api/v1" },
    { "key": "marketplace_url",  "value": "http://localhost:8000/api/v1" },
    { "key": "search_url",       "value": "http://localhost:8000/api/v1" },
    { "key": "ai_url",           "value": "http://localhost:8000/api/v1" },
    { "key": "chat_url",         "value": "http://localhost:8000/api/v1" },
    { "key": "payment_url",      "value": "http://localhost:8000/api/v1" },
    { "key": "wallet_url",       "value": "http://localhost:8000/api/v1" },
    { "key": "inventory_url",    "value": "http://localhost:8000/api/v1" },
    { "key": "logistics_url",    "value": "http://localhost:8000/api/v1" },
    { "key": "analytics_url",    "value": "http://localhost:8000/api/v1" },
    { "key": "notification_url", "value": "http://localhost:8000/api/v1" },
    { "key": "crm_url",          "value": "http://localhost:8000/api/v1" },
    { "key": "subscription_url", "value": "http://localhost:8000/api/v1" },
    { "key": "access_token",     "value": "" },
    { "key": "refresh_token",    "value": "" },
    { "key": "user_id",          "value": "" },
    { "key": "listing_id",       "value": "" },
    { "key": "payment_id",       "value": "" }
  ],
  "item": [
    {
      "name": "Gateway",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "url": "{{gateway_url}}/health" }
        },
        {
          "name": "API Root",
          "request": { "method": "GET", "url": "{{base_url}}" }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST", "url": "{{auth_url}}/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"seller@velontri.com\",\n  \"phone\": \"+2348012345678\",\n  \"password\": \"SecurePass1!\",\n  \"full_name\": \"Ada Okafor\",\n  \"country_code\": \"NG\"\n}" }
          },
          "response": [{ "name": "201 Created", "status": "Created", "code": 201,
            "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful. Please verify your phone number.\",\n  \"data\": { \"user_id\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\", \"message\": \"OTP sent to your phone\" },\n  \"meta\": null\n}" }]
        },
        {
          "name": "Verify Phone OTP",
          "request": {
            "method": "POST", "url": "{{auth_url}}/auth/verify-phone",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"otp\": \"123456\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var r = pm.response.json();",
            "if (r.success && r.data && r.data.tokens) {",
            "  pm.collectionVariables.set('access_token', r.data.tokens.access_token);",
            "  pm.collectionVariables.set('refresh_token', r.data.tokens.refresh_token);",
            "}"
          ]}}],
          "request": {
            "method": "POST", "url": "{{auth_url}}/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"identifier\": \"seller@velontri.com\",\n  \"password\": \"SecurePass1!\",\n  \"device_fingerprint\": \"web-postman-test\",\n  \"user_agent\": \"Postman/10.0\"\n}" }
          },
          "response": [{ "name": "200 OK", "status": "OK", "code": 200,
            "body": "{\n  \"success\": true,\n  \"message\": \"Operation successful\",\n  \"data\": {\n    \"tokens\": {\n      \"access_token\": \"eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...\",\n      \"refresh_token\": \"v2.local.AbCdEf...\",\n      \"expires_in\": 900\n    },\n    \"requires_2fa\": false\n  },\n  \"meta\": null\n}" }]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST", "url": "{{auth_url}}/auth/token/refresh",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST", "url": "{{auth_url}}/auth/logout",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}" }
          }
        },
        {
          "name": "Introspect Token",
          "request": {
            "method": "GET", "url": "{{auth_url}}/auth/introspect",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Request Password Reset",
          "request": {
            "method": "POST", "url": "{{auth_url}}/auth/password/reset-request",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"seller@velontri.com\"\n}" }
          }
        },
        {
          "name": "Enable 2FA (TOTP)",
          "request": {
            "method": "POST", "url": "{{auth_url}}/auth/2fa/enable",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"method\": \"totp\"\n}" }
          }
        },
        {
          "name": "Login with OAuth (Google)",
          "request": {
            "method": "POST", "url": "{{auth_url}}/auth/login/oauth",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"provider\": \"google\",\n  \"id_token\": \"<google-id-token>\",\n  \"device_fingerprint\": \"web-browser\",\n  \"user_agent\": \"Mozilla/5.0\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Marketplace — Listings",
      "item": [
        {
          "name": "Browse Listings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{marketplace_url}}/listings?page=1&page_size=20&category=Electronics",
              "host": ["{{marketplace_url}}"], "path": ["listings"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "page_size", "value": "20"},
                {"key": "category", "value": "Electronics"},
                {"key": "listing_type", "value": null, "disabled": true},
                {"key": "seller_id", "value": null, "disabled": true}
              ]
            }
          },
          "response": [{ "name": "200 OK", "code": 200,
            "body": "{\n  \"success\": true,\n  \"message\": \"150 listing(s) found.\",\n  \"data\": [\n    {\n      \"id\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n      \"title\": \"Samsung Galaxy S25 Ultra\",\n      \"price\": \"1250000.00\",\n      \"currency\": \"NGN\",\n      \"status\": \"active\",\n      \"listing_type\": \"physical\",\n      \"category\": \"Electronics\",\n      \"avg_rating\": 4.8,\n      \"review_count\": 23\n    }\n  ],\n  \"meta\": { \"page\": 1, \"page_size\": 20, \"total\": 150, \"total_pages\": 8, \"has_next\": true, \"has_prev\": false }\n}" }]
        },
        {
          "name": "Create Listing",
          "request": {
            "method": "POST", "url": "{{marketplace_url}}/listings",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"listing_type\": \"physical\",\n  \"title\": \"Samsung Galaxy S25 Ultra\",\n  \"description\": \"Brand new, sealed in box. Nigerian warranty.\",\n  \"price\": 1250000,\n  \"currency\": \"NGN\",\n  \"country\": \"NG\",\n  \"state\": \"Lagos\",\n  \"city\": \"Ikeja\",\n  \"category\": \"Electronics\",\n  \"subcategory\": \"Smartphones\",\n  \"condition\": \"new\",\n  \"brand\": \"Samsung\"\n}" }
          }
        },
        {
          "name": "Get Listing Detail",
          "request": {
            "method": "GET", "url": "{{marketplace_url}}/listings/{{listing_id}}"
          }
        },
        {
          "name": "Update Listing",
          "request": {
            "method": "PATCH", "url": "{{marketplace_url}}/listings/{{listing_id}}",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 1199000,\n  \"description\": \"Price drop! Brand new Samsung Galaxy S25 Ultra.\"\n}" }
          }
        },
        {
          "name": "Delete (Archive) Listing",
          "request": {
            "method": "DELETE", "url": "{{marketplace_url}}/listings/{{listing_id}}",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Publish Listing",
          "request": {
            "method": "POST", "url": "{{marketplace_url}}/listings/{{listing_id}}/publish",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Submit Review",
          "request": {
            "method": "POST", "url": "{{marketplace_url}}/listings/{{listing_id}}/reviews",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent product! Fast delivery and exactly as described.\"\n}" }
          }
        },
        {
          "name": "Create Booking (Service)",
          "request": {
            "method": "POST", "url": "{{marketplace_url}}/bookings",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"listing_id\": \"{{listing_id}}\",\n  \"scheduled_at\": \"2026-08-01T10:00:00Z\",\n  \"duration_minutes\": 60\n}" }
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Keyword Search",
          "request": {
            "method": "GET",
            "url": { "raw": "{{search_url}}/search?q=Samsung+Galaxy&category=Electronics&price_max=2000000",
              "query": [{"key": "q", "value": "Samsung Galaxy"}, {"key": "category", "value": "Electronics"}, {"key": "price_max", "value": "2000000"}, {"key": "city", "value": "Lagos", "disabled": true}]
            }
          }
        },
        {
          "name": "Autocomplete",
          "request": { "method": "GET", "url": "{{search_url}}/search/autocomplete?q=Toyo" }
        },
        {
          "name": "AI Natural Language Search",
          "request": {
            "method": "POST", "url": "{{search_url}}/search/ai",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"Toyota Camry under 10 million in Lagos\",\n  \"page\": 1,\n  \"page_size\": 10\n}" }
          }
        }
      ]
    },
    {
      "name": "Payments & Escrow",
      "item": [
        {
          "name": "Initiate Payment",
          "request": {
            "method": "POST", "url": "{{payment_url}}/payments/initiate",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"order_id\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n  \"buyer_id\": \"{{user_id}}\",\n  \"seller_id\": \"seller-uuid-here\",\n  \"amount\": \"1250000.00\",\n  \"currency\": \"NGN\",\n  \"seller_tier\": \"growth\",\n  \"buyer_email\": \"buyer@velontri.com\"\n}" }
          }
        },
        {
          "name": "Confirm Delivery",
          "request": {
            "method": "POST", "url": "{{payment_url}}/payments/{{payment_id}}/confirm-delivery",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Raise Dispute",
          "request": {
            "method": "POST", "url": "{{payment_url}}/payments/{{payment_id}}/dispute",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Item not as described. Received a different model.\"\n}" }
          }
        },
        {
          "name": "Get Payment",
          "request": {
            "method": "GET", "url": "{{payment_url}}/payments/{{payment_id}}",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Balance",
          "request": { "method": "GET", "url": "{{wallet_url}}/wallet/balance", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}] },
          "response": [{ "name": "200 OK", "code": 200,
            "body": "{\n  \"success\": true,\n  \"message\": \"Balance retrieved successfully.\",\n  \"data\": {\n    \"balance\": \"450000.00\",\n    \"held_balance\": \"0.00\",\n    \"available_balance\": \"450000.00\",\n    \"rewards_points\": 1250,\n    \"currency\": \"NGN\",\n    \"pending_count\": 0\n  },\n  \"meta\": null\n}" }]
        },
        {
          "name": "Top Up",
          "request": {
            "method": "POST", "url": "{{wallet_url}}/wallet/topup",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": \"50000.00\",\n  \"currency\": \"NGN\",\n  \"payment_reference\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\"\n}" }
          }
        },
        {
          "name": "Withdraw",
          "request": {
            "method": "POST", "url": "{{wallet_url}}/wallet/withdraw",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": \"25000.00\",\n  \"bank_code\": \"044\",\n  \"bank_account_number\": \"0123456789\",\n  \"description\": \"Weekly business payout\"\n}" }
          }
        },
        {
          "name": "Transfer",
          "request": {
            "method": "POST", "url": "{{wallet_url}}/wallet/transfer",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"recipient_user_id\": \"recipient-uuid-here\",\n  \"amount\": \"10000.00\",\n  \"description\": \"Payment for freelance work\"\n}" }
          }
        },
        {
          "name": "Redeem Rewards",
          "request": {
            "method": "POST", "url": "{{wallet_url}}/wallet/rewards/redeem",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"points\": 500\n}" }
          }
        },
        {
          "name": "Transaction History",
          "request": {
            "method": "GET", "url": "{{wallet_url}}/wallet/transactions?page=1&page_size=20",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        }
      ]
    },
    {
      "name": "Users & Profiles",
      "item": [
        {
          "name": "Get Profile",
          "request": { "method": "GET", "url": "{{user_url}}/users/{{user_id}}/profile" }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH", "url": "{{user_url}}/users/me/profile",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"bio\": \"Verified seller of electronics in Lagos\",\n  \"city\": \"Lagos\",\n  \"state\": \"Lagos\",\n  \"default_currency\": \"NGN\"\n}" }
          }
        },
        {
          "name": "Create Business",
          "request": {
            "method": "POST", "url": "{{user_url}}/businesses",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"business_name\": \"TechHub Nigeria Ltd\",\n  \"registration_number\": \"RC1234567\",\n  \"country\": \"NG\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "List Tiers",
          "request": { "method": "GET", "url": "{{subscription_url}}/subscriptions/tiers" },
          "response": [{ "name": "200 OK", "code": 200,
            "body": "{\n  \"success\": true,\n  \"message\": \"Subscription tiers retrieved.\",\n  \"data\": {\n    \"starter\": { \"listing_quota\": 10, \"transaction_fee_rate\": 0.025, \"cashback_rate\": 0.0, \"multi_branch\": false, \"ai_bi\": false },\n    \"growth\":  { \"listing_quota\": 100, \"transaction_fee_rate\": 0.020, \"cashback_rate\": 0.01, \"multi_branch\": true,  \"ai_bi\": false },\n    \"pro\":     { \"listing_quota\": 0,   \"transaction_fee_rate\": 0.015, \"cashback_rate\": 0.02, \"multi_branch\": true,  \"ai_bi\": true },\n    \"enterprise\": { \"listing_quota\": 0, \"transaction_fee_rate\": 0.010, \"cashback_rate\": 0.03, \"multi_branch\": true, \"ai_bi\": true }\n  },\n  \"meta\": null\n}" }]
        },
        {
          "name": "Get My Subscription",
          "request": { "method": "GET", "url": "{{subscription_url}}/subscriptions/me", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}] }
        },
        {
          "name": "Upgrade Subscription",
          "request": { "method": "POST", "url": "{{subscription_url}}/subscriptions/upgrade?new_tier=growth", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}] }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Seller Summary",
          "request": { "method": "GET", "url": "{{analytics_url}}/analytics/seller/{{user_id}}/summary?days=30", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}] }
        },
        {
          "name": "Top Listings",
          "request": { "method": "GET", "url": "{{analytics_url}}/analytics/seller/{{user_id}}/top-listings?days=30&limit=20", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}] }
        }
      ]
    },
    {
      "name": "CRM",
      "item": [
        {
          "name": "Search Customers",
          "request": { "method": "GET", "url": "{{crm_url}}/crm/customers?q=080&page=1", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}] }
        },
        {
          "name": "Get Customer",
          "request": { "method": "GET", "url": "{{crm_url}}/crm/customers/{{user_id}}", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}] }
        },
        {
          "name": "Add Note",
          "request": {
            "method": "POST", "url": "{{crm_url}}/crm/customers/{{user_id}}/notes",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": { "mode": "raw", "raw": "{\n  \"note\": \"VIP customer - prefers same-day delivery. Always pays promptly.\"\n}" }
          }
        }
      ]
    }
  ]
}
