{
  "title": "Velontri Platform Overview",
  "uid": "velontri-platform",
  "tags": ["velontri"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate (all services)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (job) (rate(velontri_http_requests_total[1m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate (5xx) by Service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (job) (rate(velontri_http_requests_total{status_code=~\"5..\"}[5m])) / sum by (job) (rate(velontri_http_requests_total[5m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 Latency by Service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(velontri_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Requests In Progress",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (job) (velontri_http_requests_in_progress)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DLQ Message Count",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages_total{queue=\"velontri.dead_letters\"}",
          "legendFormat": "DLQ messages"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Service Health",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
