##############################################################################
# Velontri Production Environment Variables
# Copy this file to .env.production and fill in all values.
# NEVER commit the actual .env.production to version control.
##############################################################################

# ── Global ────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ── Auth Service (port 8001) ──────────────────────────────────────────────────
# Path to RSA private key inside the container (stored as Docker secret)
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
# Path to RSA public key (shared with all services for JWT verification)
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
# JWT issuer claim
JWT_ISSUER=velontri-auth
# JWT audience claim
JWT_AUDIENCE=velontri-api
# Access token TTL in seconds (15 minutes)
ACCESS_TOKEN_TTL_SECONDS=900
# Refresh token TTL in days (7 days)
REFRESH_TOKEN_TTL_DAYS=7
# TOTP secret encryption key (Fernet symmetric key, 32-byte base64)
TOTP_ENCRYPTION_KEY=your-fernet-key-here

# ── Database (shared pattern — each service has its own DB) ──────────────────
# Auth service database
AUTH_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_auth
AUTH_DB_POOL_SIZE=10
AUTH_DB_MAX_OVERFLOW=20

# User service database
USER_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_users

# Marketplace service database
MARKETPLACE_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_marketplace

# Payment service database
PAYMENT_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_payments

# Wallet service database
WALLET_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_wallet

# Inventory service database
INVENTORY_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_inventory

# Logistics service database
LOGISTICS_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_logistics

# Analytics service database
ANALYTICS_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_analytics

# Notification service database
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_notifications

# CRM service database
CRM_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_crm

# Subscription service database
SUBSCRIPTION_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_subscriptions

# Chat service database
CHAT_DATABASE_URL=postgresql+asyncpg://velontri:STRONG_PASSWORD@postgres:5432/velontri_chat

# ── Redis (shared) ────────────────────────────────────────────────────────────
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_PASSWORD=your-redis-password

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://velontri:RABBITMQ_PASSWORD@rabbitmq:5672/
RABBITMQ_PASSWORD=your-rabbitmq-password
RABBITMQ_RECONNECT_DELAY=2.0
RABBITMQ_RECONNECT_MAX_DELAY=30.0

# ── Elasticsearch (Search Service) ───────────────────────────────────────────
ELASTICSEARCH_URL=https://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your-elastic-password
ELASTICSEARCH_INDEX=velontri_listings

# ── AWS S3 (File Storage) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=af-south-1
AWS_S3_BUCKET=velontri-media-production
# CDN base URL for serving uploaded files
MEDIA_CDN_URL=https://media.velontri.com
# Presigned URL TTL (seconds)
S3_PRESIGNED_URL_TTL=3600

# ── Payment Gateways ──────────────────────────────────────────────────────────
# Paystack
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_live_your_flutterwave_secret
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_live_your_flutterwave_public

# M-Pesa (Safaricom)
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_PAYBILL=your-paybill-number
MPESA_PASSKEY=your-mpesa-passkey
MPESA_ENVIRONMENT=production

# Stripe (international cards)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── Communications ────────────────────────────────────────────────────────────
# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACyour_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+14155238886

# SendGrid (Email)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@velontri.com
SENDGRID_FROM_NAME=Velontri

# Firebase Cloud Messaging (Push notifications)
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=velontri-production

# APNs (Apple Push Notifications)
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_BUNDLE_ID=com.velontri.app
APNS_KEY_PATH=/run/secrets/apns_private_key

# ── AI Service ────────────────────────────────────────────────────────────────
# OpenAI (for AI search and recommendations)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Deepgram (for voice search transcription)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://app.velontri.com,https://admin.velontri.com,https://partner.velontri.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Requests per minute per IP on auth endpoints
AUTH_RATE_LIMIT=10
# General API rate limit
API_RATE_LIMIT=300

# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry DSN for error tracking
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics endpoint password
METRICS_PASSWORD=your-metrics-password

# ── Subscription Service ──────────────────────────────────────────────────────
# Starter tier listing quota
STARTER_LISTING_QUOTA=3
# Basic tier listing quota
BASIC_LISTING_QUOTA=10
# Professional tier listing quota
PROFESSIONAL_LISTING_QUOTA=50
# Enterprise tier listing quota (0 = unlimited)
ENTERPRISE_LISTING_QUOTA=0

# ── Service Versions ──────────────────────────────────────────────────────────
# Used in health check responses and logs
SERVICE_VERSION=1.0.0
