# Auth Service — copy to .env and fill in values
# NEVER commit .env to version control

SERVICE_NAME=auth-service
SERVICE_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

DATABASE_URL=postgresql+asyncpg://velontri:velontri@localhost:5432/auth_db
REDIS_URL=redis://:velontri@localhost:6379/0
RABBITMQ_URL=amqp://velontri:velontri@localhost:5672/
AWS_S3_BUCKET=velontri-local
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

JWT_PUBLIC_KEY_PATH=./secrets/jwt_public_key.pem
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private_key.pem

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=CHANGE_ME_GENERATE_FERNET_KEY

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

SMS_PROVIDER=africastalking
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=Velontri

NOTIFICATION_SERVICE_URL=http://localhost:8012
